<AudioDestination DEF="SoundNode_soundtestzonw_Ambient" gain="0">
  <AudioClip DEF="Clip_soundtestzonw_Ambient" containerField="children" url='"media/piano1.mp3"'  loop="false" gain="1.0" startTime="-1" stopTime="-2"/>
</AudioDestination>
<Script DEF="SoundFader_soundtestzonw" directOutput="true" mustEvaluate="true">
  <field name="isActive" type="SFBool" accessType="inputOnly"/>
  <field name="playing"  type="SFBool" accessType="inputOnly"/>
  <![CDATA[ecmascript:
  var _fadeTimer=null; var _targetGain=0; var _curGain=0;
  var _playing=false;
  var FADE_MS=300; var STEPS=15;
  function _ramp(from,to){
    if(_fadeTimer){clearInterval(_fadeTimer);_fadeTimer=null;}
    _curGain=from; _targetGain=to;
    var step=(to-from)/STEPS; var interval=Math.round(FADE_MS/STEPS);
    _fadeTimer=setInterval(function(){
      _curGain+=step;
      var done=(step>0?_curGain>=_targetGain:_curGain<=_targetGain);
      if(done){_curGain=_targetGain;clearInterval(_fadeTimer);_fadeTimer=null;}
      try{var d=Browser.currentScene.getNamedNode("SoundNode_soundtestzonw_Ambient");if(d)d.gain=_curGain;}catch(e){}
    },interval);
  }
  function playing(val, time) {
    _playing = val;
    Browser.println("SoundFader_soundtestzonw: playing=" + val);
    if (!val) {
      _ramp(_curGain, 0);
      try { var clip = Browser.currentScene.getNamedNode("Clip_soundtestzonw_Ambient"); if (clip) clip.stopTime = Browser.currentTime + (FADE_MS/1000); } catch(e) {}
    }
  }
  function isActive(val, time) {
    if (!_playing) { Browser.println("SoundFader_soundtestzonw: GATED isActive="+val); return; }
    var clip = Browser.currentScene.getNamedNode("Clip_soundtestzonw_Ambient");
    if (val) {
      if (clip && clip.url && clip.url.length>0 && clip.url[0]) {
        if(clip){clip.stopTime=-2;clip.startTime=Browser.currentTime;}
        _ramp(0, 0.80);
      }
      Browser.println("SoundFader_soundtestzonw: ENTER");
    } else {
      _ramp(_curGain, 0);
      if(clip) clip.stopTime=Browser.currentTime+(FADE_MS/1000);
      Browser.println("SoundFader_soundtestzonw: EXIT");
    }
  }
  ]]>
</Script>
<!-- Track 4: Dwell one-shot — fired by loader SAI on dwell expiry -->
<AudioDestination DEF="SoundNode_soundtestzonw_Dwell" gain="0.98">
  <AudioClip DEF="Clip_soundtestzonw_Dwell" containerField="children" url='"media/soundeffects/Thunder1.mp3"' loop="false" gain="1.0" startTime="-1" stopTime="-2"/>
