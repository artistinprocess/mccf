<!-- ═══════════════════════════════════════════════════════
     ZONE: Garden
     Sound design:
       Ambient — spatialize=false, large ellipsoid covering full scene,
                 intensity=0 at start, raised by SAI from loader on file assign.
                 loop=true, startTime=-1 (never auto-fires; SAI sets startTime).
       Dwell   — spatialize=false, one-shot, triggered by SAI on dwell event.
     Distance model: minFront/maxFront define linear falloff per X3D spec.
       Inside minFront  → full intensity (1.0 × intensity field).
       minFront→maxFront → linear attenuation to 0.
       Outside maxFront → silent.
     For viewer at overview (28 units up, ~35 units away): maxFront=60 covers
     the whole scene. minFront=5 gives full volume inside the zone disc.
     ═══════════════════════════════════════════════════════ -->
<Transform DEF="Zone_Garden" translation="13.07777777777778 0 8.511111111111122">
  <Shape><Appearance><Material diffuseColor="0.533 0.533 0.533" transparency="0.55" emissiveColor="0.533 0.533 0.533"/></Appearance>
  <Cylinder height="0.5" radius="5"/></Shape>
  <Transform translation="0 3.7 0"><Billboard axisOfRotation="0 1 0"><Shape><Appearance><Material emissiveColor="0.533 0.533 0.533"/></Appearance>
  <Text string='"Garden"'><FontStyle size="0.28" family='"SANS"' justify='"MIDDLE"'/></Text></Shape></Billboard></Transform>
  <ProximitySensor DEF="Prox_Garden" size="10 4 10" enabled="true"/>
  <!-- Ambient loop -->
  <Sound DEF="SoundNode_Garden"
         location="0 1 0"
         direction="0 0 1"
         minFront="5"  minBack="5"
         maxFront="60" maxBack="60"
         intensity="0.0"
         spatialize="false"
         priority="0.5">
    <AudioClip DEF="Sound_Garden"
               containerField="source"
               loop="true"
               startTime="-1"
               stopTime="-2"/>
  </Sound>
  <!-- Dwell one-shot -->
  <Sound DEF="SoundNode_Garden_Dwell"
         location="0 1 0"
         direction="0 0 1"
         minFront="5"  minBack="5"
         maxFront="60" maxBack="60"
         intensity="0.0"
         spatialize="false"
         priority="0.8">
    <AudioClip DEF="Sound_Garden_Dwell"
               containerField="source"
               loop="false"
               startTime="-1"
               stopTime="-2"/>
  </Sound>
</Transform>

