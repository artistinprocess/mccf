<!-- ═══════════════════════════════════════════════════════
     SoundFader Script
     Receives intensity scalar writes from loader SAI.
     FadeClock uses cycleTime (SFTime wall-clock) for correct dt.
     Zone entry/exit: loader calls spSetFader() directly via SAI —
     no ProximitySensor routing needed (ProxSensors detect viewer,
     not avatars). Avatar zone detection handled in loader JS.
     ═══════════════════════════════════════════════════════ -->
<Script DEF="SoundFader" directOutput="true" mustEvaluate="true">
  <!-- Scalars: all inputOutput so loader can write them via SAI -->
  <field name="fadeInDuration"          type="SFFloat" accessType="inputOutput" value="1.5"/>
  <field name="fadeOutDuration"         type="SFFloat" accessType="inputOutput" value="2.5"/>
  <field name="masterVolume"            type="SFFloat" accessType="inputOutput" value="1.0"/>
  <field name="vol_Garden"              type="SFFloat" accessType="inputOutput" value="0.8"/>
  <field name="vol_Village_Plaza"       type="SFFloat" accessType="inputOutput" value="0.8"/>
  <field name="vol_pool"                type="SFFloat" accessType="inputOutput" value="0.8"/>
  <field name="vol_Garden_Dwell"        type="SFFloat" accessType="inputOutput" value="0.9"/>
  <field name="vol_Village_Plaza_Dwell" type="SFFloat" accessType="inputOutput" value="0.9"/>
  <field name="vol_pool_Dwell"          type="SFFloat" accessType="inputOutput" value="0.9"/>
  <!-- Zone enter/exit triggers — set from loader JS, not ProximitySensor -->
  <field name="prox_Garden"             type="SFBool"  accessType="inputOnly"/>
  <field name="prox_Village_Plaza"      type="SFBool"  accessType="inputOnly"/>
  <field name="prox_pool"               type="SFBool"  accessType="inputOnly"/>
  <!-- Dwell one-shot triggers — set from loader JS at dwell event -->
  <field name="dwell_Garden"            type="SFBool"  accessType="inputOnly"/>
  <field name="dwell_Village_Plaza"     type="SFBool"  accessType="inputOnly"/>
  <field name="dwell_pool"              type="SFBool"  accessType="inputOnly"/>
  <!-- cycleTime from FadeClock: SFTime wall-clock, fires each cycle end -->
  <field name="tick"                    type="SFTime"  accessType="inputOnly"/>
  <![CDATA[ecmascript:
  var _zones = {
    'Garden':        { nodeId:'SoundNode_Garden',        clipId:'Sound_Garden',        target:0.0, current:0.0, scalar:0.8 },
    'Village_Plaza': { nodeId:'SoundNode_Village_Plaza', clipId:'Sound_Village_Plaza', target:0.0, current:0.0, scalar:0.8 },
    'pool':          { nodeId:'SoundNode_pool',          clipId:'Sound_pool',          target:0.0, current:0.0, scalar:0.8 }
  };
  var _dwells = {
    'Garden':        { nodeId:'SoundNode_Garden_Dwell',        clipId:'Sound_Garden_Dwell',        scalar:0.9 },
    'Village_Plaza': { nodeId:'SoundNode_Village_Plaza_Dwell', clipId:'Sound_Village_Plaza_Dwell', scalar:0.9 },
    'pool':          { nodeId:'SoundNode_pool_Dwell',          clipId:'Sound_pool_Dwell',          scalar:0.9 }
  };
  var _fadeIn=1.5, _fadeOut=2.5, _master=1.0, _lastTick=-1;
  var _TICK_INTERVAL = 0.1; // matches FadeClock cycleInterval

  function initialize(){ Browser.println("SoundFader: ready"); }

  function fadeInDuration(v,t)          { _fadeIn=v; }
  function fadeOutDuration(v,t)         { _fadeOut=v; }
  function masterVolume(v,t)            { _master=v; }
  function vol_Garden(v,t)              { _zones['Garden'].scalar=v; }
  function vol_Village_Plaza(v,t)       { _zones['Village_Plaza'].scalar=v; }
  function vol_pool(v,t)                { _zones['pool'].scalar=v; }
  function vol_Garden_Dwell(v,t)        { _dwells['Garden'].scalar=v; }
  function vol_Village_Plaza_Dwell(v,t) { _dwells['Village_Plaza'].scalar=v; }
  function vol_pool_Dwell(v,t)          { _dwells['pool'].scalar=v; }

  function _setTarget(key, entering) {
    var z = _zones[key]; if(!z) return;
    z.target = entering ? (z.scalar * _master) : 0.0;
    if(entering) {
      // Start clip playing if a url is loaded — SAI sets url before calling this
      try {
        var ac = Browser.currentScene.getNamedNode(z.clipId);
        if(ac) {
          ac.stopTime  = -1;
          ac.startTime = Browser.currentTime + 0.05;
        }
      } catch(e) {}
    }
    Browser.println("SoundFader: " + key + (entering ? " ENTER" : " EXIT") + " target=" + z.target);
  }

  function prox_Garden(val,t)        { _setTarget('Garden',val); }
  function prox_Village_Plaza(val,t) { _setTarget('Village_Plaza',val); }
  function prox_pool(val,t)          { _setTarget('pool',val); }

  function _fireDwell(key, val) {
    if(!val) return;
    var d = _dwells[key]; if(!d) return;
    try {
      var snd = Browser.currentScene.getNamedNode(d.nodeId);
      var ac  = Browser.currentScene.getNamedNode(d.clipId);
      if(snd && ac) {
        snd.intensity = d.scalar * _master;
        ac.stopTime   = -1;
        ac.startTime  = Browser.currentTime + 0.05;
        Browser.println("SoundFader: dwell " + key + " vol=" + snd.intensity);
      }
    } catch(e) { Browser.println("SoundFader dwell err " + key + ": " + e); }
  }

  function dwell_Garden(val,t)        { _fireDwell('Garden',val); }
  function dwell_Village_Plaza(val,t) { _fireDwell('Village_Plaza',val); }
  function dwell_pool(val,t)          { _fireDwell('pool',val); }

  // tick receives cycleTime — a real SFTime wall-clock value.
  // dt is always _TICK_INTERVAL (FadeClock fires exactly each cycleInterval).
  function tick(t) {
    var dt = _TICK_INTERVAL;
    var keys = ['Garden','Village_Plaza','pool'];
    for(var i=0; i<keys.length; i++) {
      var z = _zones[keys[i]];
      if(Math.abs(z.current - z.target) < 0.004) {
        z.current = z.target;
      } else {
        var rate = (z.target > z.current) ? (1.0 / _fadeIn) : (1.0 / _fadeOut);
        var step = rate * dt;
        z.current = (z.target > z.current)
          ? Math.min(z.current + step, z.target)
          : Math.max(z.current - step, z.target);
      }
      try {
        var snd = Browser.currentScene.getNamedNode(z.nodeId);
        if(snd) snd.intensity = z.current;
      } catch(e) {}
    }
  }
  ]]>
</Script>

<!-- FadeClock: cycleTime fires once per cycle at real wall-clock time.
     cycleInterval=0.1 → 10 ticks/sec → smooth 1.5s fade-in, 2.5s fade-out. -->
<TimeSensor DEF="FadeClock" cycleInterval="0.1" loop="true" enabled="true"/>

