<!-- Animation: Jack — Pool to Garden -->
<!-- Segment 1: Pool -> Garden dist=17.6m pace=1.4m/s travel=12.55s dwell=2.0s -->
<PositionInterpolator DEF="Interp_Jack_1" key="0 1" keyValue="30 0 7 12.788888888888913 0 10.51111111111111"/>
<TimeSensor DEF="Timer_Jack_1" cycleInterval="12.55" loop="false" enabled="false"/>
<TimeSensor DEF="Dwell_Jack_1" cycleInterval="2.0"   loop="false" enabled="false"/>

<Script DEF="Arrival_Jack" directOutput="true" mustEvaluate="true">
  <field name="waypointOrder"   type="SFInt32" accessType="initializeOnly" value="2"/>
  <field name="startFromLoader" type="SFTime"  accessType="inputOnly"/>
  <field name="arrived"         type="SFBool"  accessType="inputOnly"/>
  <field name="releaseDwell"    type="SFBool"  accessType="inputOnly"/>
  <field name="advanceSeg"      type="SFInt32" accessType="inputOnly"/>
  <field name="resetSeg"        type="SFBool"  accessType="inputOnly"/>
  <field name="segmentArrived"  type="SFInt32" accessType="outputOnly"/>
  <![CDATA[ecmascript:
  var _seg=0, _wasActive=false;
  var _timerIds=['Timer_Jack_1'];
  var _dwellIds=['Dwell_Jack_1'];
  var _maxSeg=1;
  function initialize(){ Browser.println("Arrival_Jack: ready maxSeg="+_maxSeg+" order=2"); }
  function resetSeg(val,time){ if(!val)return; _seg=0; _wasActive=false; }
  function startFromLoader(val,time){
    if(val<=0)return;
    try{ var t=Browser.currentScene.getNamedNode(_timerIds[0]);
      if(t){t.startTime=time+0.1;t.enabled=true;Browser.println("Arrival_Jack: Timer_1 at "+(time+0.1));}
    }catch(e){Browser.println("Arrival_Jack startFromLoader err: "+e);}
  }
  function arrived(val,time){
    if(val){ _wasActive=true; return; }
    if(!_wasActive) return;
    _wasActive=false; _seg++; segmentArrived=_seg;
    Browser.println("Arrival_Jack: arrived seg "+_seg);
  }
  function advanceSeg(completedSeg,time){
    var nextIdx=completedSeg;
    if(nextIdx>=_maxSeg){ Browser.println("Arrival_Jack: arc complete"); return; }
    var tNow=(time&&time>0)?time:Browser.currentTime;
    try{ var t=Browser.currentScene.getNamedNode(_timerIds[nextIdx]);
      if(t){t.startTime=tNow;t.enabled=true;Browser.println("Arrival_Jack: Timer_"+(nextIdx+1)+" at "+tNow);}
    }catch(e){Browser.println("Arrival_Jack advanceSeg err: "+e);}
  }
  function releaseDwell(val,time){
    if(!val||_seg<1)return;
    if(_seg>_dwellIds.length)return;
    var dwId=_dwellIds[_seg-1];
    try{
      var dw=Browser.currentScene.getNamedNode(dwId);
      dw.enabled=true; dw.startTime=Browser.currentTime;
      Browser.println("Arrival_Jack: released dwell "+dwId);
    }catch(e){Browser.println("Arrival_Jack releaseDwell error: "+e);}
  }
  ]]>
</Script>

<Script DEF="Kill_Jack" directOutput="true" mustEvaluate="true">
  <field name="killAll"  type="SFBool" accessType="inputOnly"/>
  <field name="resetPos" type="SFBool" accessType="inputOnly"/>
  <![CDATA[ecmascript:
  var timerIds=['Timer_Jack_1','Dwell_Jack_1'];
  var startX=30, startY=0, startZ=7;
  function killAll(val,time){
    if(!val)return;
    for(var i=0;i<timerIds.length;i++){try{Browser.currentScene.getNamedNode(timerIds[i]).enabled=false;}catch(e){}}
  }
  function resetPos(val,time){
    if(!val)return; killAll(true,time);
    try{var av=Browser.currentScene.getNamedNode("Avatar_Jack");av.translation=new SFVec3f(startX,startY,startZ);}catch(e){Browser.println("Kill_Jack resetPos err: "+e);}
    try{Browser.currentScene.getNamedNode("Arrival_Jack").resetSeg=true;}catch(e){}
  }
  ]]>
</Script>

<!-- Animation: Salida — Plaza to Garden -->
<!-- Segment 1: plaza -> Garden dist=19.8m pace=1.4m/s travel=14.16s dwell=2.0s -->
<PositionInterpolator DEF="Interp_Salida_1" key="0 1" keyValue="26.399999999999963 0 24.922222222222207 12.788888888888913 0 10.51111111111111"/>
<TimeSensor DEF="Timer_Salida_1" cycleInterval="14.16" loop="false" enabled="false"/>
<TimeSensor DEF="Dwell_Salida_1" cycleInterval="2.0"   loop="false" enabled="false"/>

<Script DEF="Arrival_Salida" directOutput="true" mustEvaluate="true">
  <field name="waypointOrder"   type="SFInt32" accessType="initializeOnly" value="2"/>
  <field name="startFromLoader" type="SFTime"  accessType="inputOnly"/>
  <field name="arrived"         type="SFBool"  accessType="inputOnly"/>
  <field name="releaseDwell"    type="SFBool"  accessType="inputOnly"/>
  <field name="advanceSeg"      type="SFInt32" accessType="inputOnly"/>
  <field name="resetSeg"        type="SFBool"  accessType="inputOnly"/>
  <field name="segmentArrived"  type="SFInt32" accessType="outputOnly"/>
  <![CDATA[ecmascript:
  var _seg=0, _wasActive=false;
  var _timerIds=['Timer_Salida_1'];
  var _dwellIds=['Dwell_Salida_1'];
  var _maxSeg=1;
  function initialize(){ Browser.println("Arrival_Salida: ready maxSeg="+_maxSeg+" order=2"); }
  function resetSeg(val,time){ if(!val)return; _seg=0; _wasActive=false; }
  function startFromLoader(val,time){
    if(val<=0)return;
    try{ var t=Browser.currentScene.getNamedNode(_timerIds[0]);
      if(t){t.startTime=time+0.1;t.enabled=true;Browser.println("Arrival_Salida: Timer_1 at "+(time+0.1));}
    }catch(e){Browser.println("Arrival_Salida startFromLoader err: "+e);}
  }
  function arrived(val,time){
    if(val){ _wasActive=true; return; }
    if(!_wasActive) return;
    _wasActive=false; _seg++; segmentArrived=_seg;
    Browser.println("Arrival_Salida: arrived seg "+_seg);
  }
  function advanceSeg(completedSeg,time){
    var nextIdx=completedSeg;
    if(nextIdx>=_maxSeg){ Browser.println("Arrival_Salida: arc complete"); return; }
    var tNow=(time&&time>0)?time:Browser.currentTime;
    try{ var t=Browser.currentScene.getNamedNode(_timerIds[nextIdx]);
      if(t){t.startTime=tNow;t.enabled=true;Browser.println("Arrival_Salida: Timer_"+(nextIdx+1)+" at "+tNow);}
    }catch(e){Browser.println("Arrival_Salida advanceSeg err: "+e);}
  }
  function releaseDwell(val,time){
    if(!val||_seg<1)return;
    if(_seg>_dwellIds.length)return;
    var dwId=_dwellIds[_seg-1];
    try{
      var dw=Browser.currentScene.getNamedNode(dwId);
      dw.enabled=true; dw.startTime=Browser.currentTime;
      Browser.println("Arrival_Salida: released dwell "+dwId);
    }catch(e){Browser.println("Arrival_Salida releaseDwell error: "+e);}
  }
  ]]>
</Script>

<Script DEF="Kill_Salida" directOutput="true" mustEvaluate="true">
  <field name="killAll"  type="SFBool" accessType="inputOnly"/>
  <field name="resetPos" type="SFBool" accessType="inputOnly"/>
  <![CDATA[ecmascript:
  var timerIds=['Timer_Salida_1','Dwell_Salida_1'];
  var startX=26.399999999999963, startY=0, startZ=24.922222222222207;
  function killAll(val,time){
    if(!val)return;
    for(var i=0;i<timerIds.length;i++){try{Browser.currentScene.getNamedNode(timerIds[i]).enabled=false;}catch(e){}}
  }
  function resetPos(val,time){
    if(!val)return; killAll(true,time);
    try{var av=Browser.currentScene.getNamedNode("Avatar_Salida");av.translation=new SFVec3f(startX,startY,startZ);}catch(e){Browser.println("Kill_Salida resetPos err: "+e);}
    try{Browser.currentScene.getNamedNode("Arrival_Salida").resetSeg=true;}catch(e){}
  }
  ]]>
</Script>

<Script DEF="MCCFMaster" directOutput="true" mustEvaluate="true">
  <field accessType="initializeOnly" type="SFString" name="api_url"             value="http://localhost:5000"/>
  <field accessType="inputOnly"      type="SFString" name="startAgent"/>
  <field accessType="inputOnly"      type="SFString" name="releaseDwellAgent"/>
  <field accessType="inputOnly"      type="SFString" name="startNextTimer"/>
  <field accessType="inputOnly"      type="SFVec3f"  name="pos_Jack"/>
  <field accessType="outputOnly"     type="SFFloat"  name="arousal_Jack"/>
  <field accessType="inputOnly"      type="SFVec3f"  name="pos_Salida"/>
  <field accessType="outputOnly"     type="SFFloat"  name="arousal_Salida"/>
  <field accessType="inputOnly"      type="SFBool"   name="zoneActive_Garden"/>
  <field accessType="inputOnly"      type="SFBool"   name="zoneActive_Village_Plaza"/>
  <field accessType="inputOnly"      type="SFBool"   name="zoneActive_pool"/>
  <![CDATA[ecmascript:
  var _sceneNow=0;
  function _getSceneNow(agent,seg){var t=Browser.currentScene.getNamedNode("Timer_"+agent+"_"+seg);if(t&&t.time!==undefined&&t.time>0)return t.time;if(t&&t.startTime!==undefined&&t.cycleTime!==undefined&&(t.startTime+t.cycleTime)>0)return t.startTime+t.cycleTime;return _sceneNow;}
  function initialize(){Browser.println("MCCFMaster initialized.");}
  function startNextTimer(agentColonSeg,time){
    try{
      var parts=agentColonSeg.split(":");
      var nextSeg=parseInt(parts[1])+1;
      var t=Browser.currentScene.getNamedNode("Timer_"+parts[0]+"_"+nextSeg);
      if(t){t.startTime=time;t.enabled=true;Browser.println("MCCFMaster: Timer_"+parts[0]+"_"+nextSeg+" at "+time);}
      else{Browser.println("MCCFMaster: no Timer_"+parts[0]+"_"+nextSeg+" arc complete");}
    }catch(e){Browser.println("MCCFMaster: startNextTimer — "+e.message);}
  }
  function startAgent(agentSafeName,time){
    var t=Browser.currentScene.getNamedNode("Timer_"+agentSafeName+"_1");
    if(t){t.startTime=time;t.enabled=true;_sceneNow=time;Browser.println("MCCFMaster: Timer_"+agentSafeName+"_1 at "+time);}
    else{Browser.println("MCCFMaster: Timer_"+agentSafeName+"_1 NOT FOUND");}
  }
  function releaseDwellAgent(agentColonSeg,time){
    var parts=agentColonSeg.split(":");
    var dw=Browser.currentScene.getNamedNode("Dwell_"+parts[0]+"_"+parts[1]);
    if(dw){var tNow=_getSceneNow(parts[0],parseInt(parts[1]));dw.startTime=tNow;dw.enabled=true;Browser.println("MCCFMaster: Dwell_"+parts[0]+"_"+parts[1]+" at "+tNow);}
    else{Browser.println("MCCFMaster: Dwell_"+parts[0]+"_"+parts[1]+" NOT FOUND");}
  }
  ]]>
</Script>

<!-- ═══════════════════════════════════════════════════
     ROUTEs
     NOTE: Sound zone entry/exit is handled by loader JS (spTriggerZone)
     not by ProximitySensor ROUTEs — ProxSensors detect the viewer camera,
     not avatar positions. Loader watches interpolator output and calls
     SoundFader.prox_* via SAI when avatar enters/exits a zone radius.
     ═══════════════════════════════════════════════════ -->

<!-- Jack animation chain -->
<ROUTE fromNode="Timer_Jack_1"  fromField="fraction_changed" toNode="Interp_Jack_1" toField="set_fraction"/>
<ROUTE fromNode="Interp_Jack_1" fromField="value_changed"    toNode="Avatar_Jack"   toField="translation"/>
<ROUTE fromNode="Timer_Jack_1"  fromField="isActive"         toNode="Arrival_Jack"  toField="arrived"/>
<ROUTE fromNode="Arrival_Jack"  fromField="segmentArrived"   toNode="Arrival_Jack"  toField="advanceSeg"/>
<ROUTE fromNode="Dwell_Jack_1"  fromField="isActive"         toNode="Arrival_Jack"  toField="releaseDwell"/>

<!-- Salida animation chain -->
<ROUTE fromNode="Timer_Salida_1"  fromField="fraction_changed" toNode="Interp_Salida_1" toField="set_fraction"/>
<ROUTE fromNode="Interp_Salida_1" fromField="value_changed"    toNode="Avatar_Salida"   toField="translation"/>
<ROUTE fromNode="Timer_Salida_1"  fromField="isActive"         toNode="Arrival_Salida"  toField="arrived"/>
<ROUTE fromNode="Arrival_Salida"  fromField="segmentArrived"   toNode="Arrival_Salida"  toField="advanceSeg"/>
<ROUTE fromNode="Dwell_Salida_1"  fromField="isActive"         toNode="Arrival_Salida"  toField="releaseDwell"/>

<!-- MCCFMaster position feeds -->
<ROUTE fromNode="Interp_Jack_1"   fromField="value_changed" toNode="MCCFMaster" toField="pos_Jack"/>
<ROUTE fromNode="Interp_Salida_1" fromField="value_changed" toNode="MCCFMaster" toField="pos_Salida"/>

<!-- Zone prox → MCCFMaster (viewer-based, for scene presence detection) -->
<ROUTE fromNode="Prox_Garden"        fromField="isActive" toNode="MCCFMaster" toField="zoneActive_Garden"/>
<ROUTE fromNode="Prox_Village_Plaza" fromField="isActive" toNode="MCCFMaster" toField="zoneActive_Village_Plaza"/>
<ROUTE fromNode="Prox_pool"          fromField="isActive" toNode="MCCFMaster" toField="zoneActive_pool"/>

<!-- FadeClock cycleTime → SoundFader tick (real wall-clock SFTime) -->
<ROUTE fromNode="FadeClock" fromField="cycleTime" toNode="SoundFader" toField="tick"/>

</Scene>
</X3D>
