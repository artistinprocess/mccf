    <!-- ═══════════════════════════════════════════════════
         MCCF Master Script
         Thin router: polls /field, writes to avatar fields.
         Does not compute pull or coherence — Python only.
         Falls back gracefully if backend unreachable.
         ═══════════════════════════════════════════════════ -->
    <Script DEF="MCCFMasterScript"
            directOutput="true"
            mustEvaluate="true">

      <field accessType="initializeOnly" type="SFString"
             name="apiUrl" value="http://localhost:5000"/>
      
        <field accessType="outputOnly" type="SFFloat" name="TheWitness_eLean"/>
        <field accessType="outputOnly" type="SFFloat" name="TheWitness_bStability"/>
        <field accessType="outputOnly" type="SFFloat" name="TheWitness_pOrientation"/>
        <field accessType="outputOnly" type="SFFloat" name="TheWitness_sApproach"/>
        <field accessType="outputOnly" type="SFFloat" name="TheWitness_arousal"/>
        <field accessType="outputOnly" type="SFColor" name="TheWitness_auraColor"/>

      <![CDATA[ecmascript:
        
      function initialize() {
        pollField();
      }

      function pollField() {
        try {
          var req = new XMLHttpRequest();
          req.open('GET', 'http://localhost:5000/field', false);
          req.send();
          if (req.status === 200) {
            var data = JSON.parse(req.responseText);
            updateAvatars(data);
          }
        } catch(e) {
          // Backend unreachable — retain current values, try again next poll
        }
        Browser.callLater(200, pollField);
      }

      function updateAvatars(fieldData) {
        var agentData = {};
        // Flatten agent state from field response
        // /field returns agents dict with summary per agent
        var agents = fieldData.agents || {};
        for (var name in agents) {
          var ag = agents[name];
          // Channel state from summary — weights are the current channel values
          var w = ag.weights || {};
          agentData[name] = {
            E: w.E || 0.5,
            B: w.B || 0.5,
            P: w.P || 0.5,
            S: w.S || 0.5
          };
        }
        
          // Agent: The Witness
          var ag_TheWitness = agentData['The Witness'];
          if (ag_TheWitness) {
            var E_TheWitness = ag_TheWitness.E || 0.5;
            var B_TheWitness = ag_TheWitness.B || 0.5;
            var P_TheWitness = ag_TheWitness.P || 0.5;
            var S_TheWitness = ag_TheWitness.S || 0.5;
            TheWitness_eLean        = E_TheWitness * 0.28;
            TheWitness_bStability   = 0.88 + B_TheWitness * (1.08 - 0.88);
            TheWitness_pOrientation = (P_TheWitness - 0.5) * 1.57;
            TheWitness_sApproach    = (S_TheWitness - 0.5) * 2.0;
            var ar_TheWitness = E_TheWitness * 0.6 + S_TheWitness * 0.4;
            TheWitness_arousal = 0.5 + ar_TheWitness * 1.5;
            var base_TheWitness = [0.376, 0.659, 0.941];
            var ei_TheWitness = 0.6 + E_TheWitness * 0.4;
            TheWitness_auraColor = new SFColor(
              Math.min(1.0, base_TheWitness[0] * ei_TheWitness),
              Math.min(1.0, base_TheWitness[1] * ei_TheWitness),
              Math.min(1.0, base_TheWitness[2] * ei_TheWitness)
            );
          }
      }
      ]]>
    </Script>

    <!-- ROUTE: Master Script → Avatar channel fields -->
    <ROUTE fromNode="MCCFMasterScript" fromField="TheWitness_eLean" toNode="Avatar_TheWitness" toField="eLean"/>
