    <ROUTE fromNode="MCCFMasterScript" fromField="TheWitness_pOrientation" toNode="Avatar_TheWitness" toField="pOrientation"/>
    <ROUTE fromNode="MCCFMasterScript" fromField="TheWitness_sApproach" toNode="Avatar_TheWitness" toField="sApproach"/>
    <ROUTE fromNode="MCCFMasterScript" fromField="TheWitness_arousal" toNode="Avatar_TheWitness" toField="arousal"/>
    <ROUTE fromNode="MCCFMasterScript" fromField="TheWitness_auraColor" toNode="Avatar_TheWitness" toField="currentAuraColor"/>

