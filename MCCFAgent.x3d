<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE X3D PUBLIC "ISO//Web3D//DTD X3D 4.0//EN"
  "https://www.web3d.org/specifications/x3d-4.0.dtd">
<X3D profile="Immersive" version="4.0"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema-instance"
  xsd:noNamespaceSchemaLocation="https://www.web3d.org/specifications/x3d-4.0.xsd">

  <!--
    MCCFAgent PROTO v2.0
    ====================
    Composable avatar driven by MCCF HotHouse field state.

    Parameter mapping from HotHouseX3DAdapter.generate_x3d_state():
      morphWeight_emotion  → E channel → facial emissive intensity
      animationSpeed       → B channel → body animation rate
      gazeDirectness       → P channel → head orientation toward scene
      socialProximity      → S channel → ring radius (social field size)
      gestureConfidence    → ideology_coherence() → gesture hold time
      interactionOpenness  → evaluative_gate_open() → ring opacity
      honorLevel           → honor constraint → gold indicator brightness
      mutualGaze_[other]   → entanglement → line opacity (set by MCCFChannel)

    Body structure:
      Floor ring  — social field (S channel, radius scales)
      Cylinder    — body (color = cultivar identity, emissive = E channel)
      Sphere      — head (neutral skin tone)
      Honor dot   — small gold sphere above head (honor level)
      Name label  — Billboard text

    All animatable fields are inputOutput so ROUTEs can drive them
    from JavaScript polling of /hothouse/x3d.
  -->

  <ProtoDeclare name="MCCFAgent">
    <ProtoInterface>

      <!-- Identity -->
      <field name="agentName"         accessType="initializeOnly" type="SFString" value="Agent"/>
      <field name="position"          accessType="inputOutput"    type="SFVec3f"  value="0 0 0"/>
      <field name="bodyColor"         accessType="initializeOnly" type="SFColor"  value="0.3 0.55 0.9"/>

      <!-- MCCF HotHouse channels — driven by /hothouse/x3d polling -->
      <field name="morphWeight_emotion"  accessType="inputOutput" type="SFFloat" value="0.5"/>
      <field name="animationSpeed"       accessType="inputOutput" type="SFFloat" value="0.5"/>
      <field name="gazeDirectness"       accessType="inputOutput" type="SFFloat" value="0.5"/>
      <field name="socialProximity"      accessType="inputOutput" type="SFFloat" value="0.5"/>
      <field name="gestureConfidence"    accessType="inputOutput" type="SFFloat" value="0.5"/>
      <field name="interactionOpenness"  accessType="inputOutput" type="SFFloat" value="1.0"/>
      <field name="honorLevel"           accessType="inputOutput" type="SFFloat" value="0.5"/>

      <!-- Coherence state — overall relationship health -->
      <field name="coherenceLevel"       accessType="inputOutput" type="SFFloat" value="0.5"/>

      <!-- Behavioral mode string for external logic -->
      <field name="behavioralMode"       accessType="inputOutput" type="SFString" value="exploit"/>

    </ProtoInterface>

    <ProtoBody>

      <Transform DEF="AgentRoot">

        <!-- Social field ring — radius driven by socialProximity -->
        <Transform translation="0 0.04 0">
          <Shape DEF="SocialRing">
            <Appearance>
              <Material DEF="RingMat"
                        emissiveColor="0.3 0.6 1.0"
                        transparency="0.55"/>
            </Appearance>
            <Cylinder DEF="RingGeom" height="0.04" radius="0.75"/>
          </Shape>
        </Transform>

        <!-- Body cylinder — emissive intensity driven by morphWeight_emotion -->
        <Transform translation="0 0.9 0">
          <Shape>
            <Appearance>
              <Material DEF="BodyMat"
                        diffuseColor="0.30 0.55 0.90"
                        emissiveColor="0.03 0.07 0.18"
                        specularColor="0.5 0.6 0.9"
                        shininess="0.65"/>
            </Appearance>
            <Cylinder height="1.35" radius="0.33"/>
          </Shape>
        </Transform>

        <!-- Head sphere -->
        <Transform translation="0 1.85 0">
          <Shape>
            <Appearance>
              <Material DEF="HeadMat"
                        diffuseColor="0.88 0.78 0.68"
                        shininess="0.3"/>
            </Appearance>
            <Sphere radius="0.30"/>
          </Shape>
        </Transform>

        <!-- Honor indicator — brightness driven by honorLevel -->
        <Transform translation="0 2.35 0">
          <Shape>
            <Appearance>
              <Material DEF="HonorMat"
                        emissiveColor="0.9 0.75 0.1"
                        transparency="0.3"/>
            </Appearance>
            <Sphere radius="0.10"/>
          </Shape>
        </Transform>

        <!-- Gaze direction indicator — small sphere offset by gazeDirectness -->
        <Transform DEF="GazeIndicator" translation="0 1.85 0.35">
          <Shape>
            <Appearance>
              <Material DEF="GazeMat"
                        emissiveColor="1.0 1.0 1.0"
                        transparency="0.6"/>
            </Appearance>
            <Sphere radius="0.06"/>
          </Shape>
        </Transform>

        <!-- Name label — Billboard faces camera always -->
        <Transform translation="0 2.75 0">
          <Billboard axisOfRotation="0 1 0">
            <Shape>
              <Appearance>
                <Material DEF="LabelMat" emissiveColor="0.6 0.8 1.0"/>
              </Appearance>
              <Text DEF="NameText" string='"Agent"'>
                <FontStyle size="0.26" justify='"MIDDLE" "MIDDLE"' family='"SANS"'/>
              </Text>
            </Shape>
          </Billboard>
        </Transform>

      </Transform>

      <!--
        JavaScript-driven animation bindings.
        These ScalarInterpolators provide smooth transitions
        when field values update via JavaScript ROUTE injection.

        Usage from mccf_x3d_loader.html polling loop:
          node.morphWeight_emotion = newValue;
          node.honorLevel = newValue;
          etc.

        Full SAI-driven animation (TimeSensor + Interpolator ROUTEs)
        can be added here as the character library matures.
        For now, direct field assignment via JavaScript is the
        primary update mechanism.
      -->

    </ProtoBody>
  </ProtoDeclare>

</X3D>
