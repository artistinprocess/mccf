<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE X3D PUBLIC "ISO//Web3D//DTD X3D 4.0//EN"
  "https://www.web3d.org/specifications/x3d-4.0.dtd">
<X3D profile="Immersive" version="4.0"
  xmlns:xsd="http://www.w3.org/2001/XMLSchema-instance"
  xsd:noNamespaceSchemaLocation="https://www.web3d.org/specifications/x3d-4.0.xsd">

  <!--
    MCCFTransition PROTO v2.0
    =========================
    Manages smooth visual transitions when MCCF field state changes.

    The original ChatGPT proposal routed Clock.cycleTime to trigger,
    which fires once per cycle (an SFTime event). This is corrected
    here to use Clock.fraction_changed (SFFloat 0.0→1.0) routed to
    interpolators, producing smooth continuous animation rather than
    discrete jumps.

    Use cases:
      - Waypoint transition: scene color shift W1→W2→...→W7
      - Coherence drop: warning flash on field origin
      - Collapse event: global color/light pulse

    Fields:
      fraction      — drive from TimeSensor.fraction_changed
      fromColor     — starting color
      toColor       — target color
      colorOut      — interpolated output → route to Material.diffuseColor
      intensityOut  — interpolated float → route to light intensity

    Instantiation example:
      <TimeSensor DEF="WaypointClock" cycleInterval="2.0" loop="false"/>
      <MCCFTransition DEF="T_W1_W2"
                      fromColor="0.9 0.9 0.9"
                      toColor="0.9 0.85 0.5"/>
      <ROUTE fromNode="WaypointClock" fromField="fraction_changed"
             toNode="T_W1_W2"        toField="fraction"/>
      <ROUTE fromNode="T_W1_W2"      fromField="colorOut"
             toNode="WaypointSphere" toField="set_diffuseColor"/>
  -->

  <ProtoDeclare name="MCCFTransition">
    <ProtoInterface>

      <!-- Drive this from TimeSensor.fraction_changed (NOT cycleTime) -->
      <field name="fraction"     accessType="inputOnly"   type="SFFloat"  value="0.0"/>

      <!-- Color interpolation -->
      <field name="fromColor"    accessType="initializeOnly" type="SFColor" value="0.5 0.5 0.5"/>
      <field name="toColor"      accessType="initializeOnly" type="SFColor" value="1.0 0.8 0.2"/>
      <field name="colorOut"     accessType="outputOnly"     type="SFColor"/>

      <!-- Scalar interpolation (intensity, opacity, scale) -->
      <field name="fromValue"    accessType="initializeOnly" type="SFFloat" value="0.5"/>
      <field name="toValue"      accessType="initializeOnly" type="SFFloat" value="1.0"/>
      <field name="valueOut"     accessType="outputOnly"     type="SFFloat"/>

      <!-- Transition type: "linear" or "pulse" -->
      <field name="transitionType" accessType="initializeOnly" type="SFString" value="linear"/>

    </ProtoInterface>

    <ProtoBody>

      <!--
        ColorInterpolator: 2-key linear blend from fromColor to toColor.
        fraction (0.0→1.0) drives the interpolation.
        Route fraction → set_fraction, colorOut → your target material.
      -->
      <ColorInterpolator DEF="ColorInterp"
                         key="0.0 1.0"
                         keyValue="0.5 0.5 0.5  1.0 0.8 0.2"/>

      <!--
        ScalarInterpolator: 2-key linear blend from fromValue to toValue.
        Use for opacity, intensity, scale transitions.
      -->
      <ScalarInterpolator DEF="ScalarInterp"
                          key="0.0 1.0"
                          keyValue="0.5 1.0"/>

      <!--
        Internal routes: fraction → interpolators → outputs.
        These wire the interpolators to their inputs.
        The outputs (colorOut, valueOut) are routed externally
        by the scene that uses MCCFTransition.
      -->
      <ROUTE fromNode="ColorInterp"  fromField="value_changed"
             toNode="MCCFTransition" toField="colorOut"/>

      <ROUTE fromNode="ScalarInterp" fromField="value_changed"
             toNode="MCCFTransition" toField="valueOut"/>

      <!--
        ECMAScript bridge: receives fraction, drives both interpolators.
        This allows the pulse transitionType to add an ease-in-out curve.
      -->
      <Script DEF="TransitionScript" mustEvaluate="true">
        <field accessType="inputOnly"   type="SFFloat" name="set_fraction"/>
        <field accessType="outputOnly"  type="SFFloat" name="colorFraction"/>
        <field accessType="outputOnly"  type="SFFloat" name="scalarFraction"/>
        <field accessType="initializeOnly" type="SFString" name="mode" value="linear"/>
        <![CDATA[
          ecmascript:
          function set_fraction(f, t) {
            var out;
            if (mode === 'pulse') {
              // Ease in-out: smooth step
              out = f * f * (3.0 - 2.0 * f);
            } else {
              out = f;
            }
            colorFraction  = out;
            scalarFraction = out;
          }
        ]]>
      </Script>

      <ROUTE fromNode="TransitionScript" fromField="colorFraction"
             toNode="ColorInterp"        toField="set_fraction"/>

      <ROUTE fromNode="TransitionScript" fromField="scalarFraction"
             toNode="ScalarInterp"       toField="set_fraction"/>

    </ProtoBody>
  </ProtoDeclare>

</X3D>
